# ==========================================
# SERVER CONFIG
# ==========================================
PORT=5000
NODE_ENV=development

# ==========================================
# DATABASE CONFIG
# ==========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=attendance_db

# ==========================================
# JWT CONFIG
# ==========================================
JWT_SECRET=attendance_system_jwt_secret_key_2026_super_secure_min_32_chars
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=attendance_system_refresh_secret_key_2026_super_secure_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# EMAIL CONFIG
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourcompany@gmail.com
SMTP_PASS=your_google_app_password
EMAIL_FROM=noreply@attendance-system.com

# ==========================================
# FRONTEND URLS
# ==========================================
CLIENT_URL=http://localhost:5173
MOBILE_URL=exp://192.168.1.10:8081

# ==========================================
# FILE UPLOAD CONFIG
# ==========================================
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# ==========================================
# RATE LIMIT CONFIG
# ==========================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ==========================================
# OFFICE TIMING CONFIG
# ==========================================
OFFICE_START_HOUR=9
OFFICE_START_MINUTE=0
LATE_THRESHOLD_MINUTES=15